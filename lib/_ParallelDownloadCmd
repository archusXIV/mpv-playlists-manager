#!/usr/bin/env bash
## This is a part of main script: mpm.

# shellcheck disable=SC2154
_ParallelDownloadCmd() {

    : "${parallel_audio_jobs:=6}"
    : "${parallel_video_jobs:=3}"

    local pid

    __cleanListsAndTitles() {
        if [[ $selectedList == 'true' ]]; then
            # we must preserve $SELECTED_URLS1 & $SELECTED_TITLES from being erased
            # because they are parsed in the _UpdateSelected function later on.
            :
        else
            sed -i '1,$d' {"$M3UFILE","$TITLES"}
            [[ $M3UFILE == "$DEFAULT_LIST" ]] && echo "#EXTM3U" > "$DEFAULT_LIST"            
        fi
        rm -f {"$JOBSLIST","$tmp_dir"/parallel.log}
        clear
    }

    declare -a ytfmt=(
        "yt-dlp --format"
        "bestaudio"
        "bestvideo+bestaudio/best"
        "${ytdlPreset_MR[@]}"
    )

    __sedAudioVideoCmd() {
        # we use commas instead of slashes as fields separators,
        # because we need ${ytfmt[@]:1:2} outside of sed too but later in option xargs.
        case $1 in
            audio) sed -i "s,^,${ytfmt[0]} ${ytfmt[1]} ${ytdlPreset_NC[*]} ," "$2" ;;
            video)
                if [[ ${ytdlPreset_MR[*]} ]]; then
                    sed -i "s,^,${ytfmt[0]} ${ytfmt[3]} ${ytdlPreset_X[*]} ," "$2"
                else
                    sed -i "s,^,${ytfmt[0]} ${ytfmt[2]} ${ytdlPreset_X[*]} ," "$2"
                fi
            ;;
        esac
    }

    __waitForPidToFinish() { pid=$!; wait "$pid"; }

    case $1 in
        parallel)
            case "$2" in
                --choose-audio|--choose-video)
                    cp "$M3UFILE" "$JOBSLIST"
                    if [[ $2 == "--choose-audio" ]]; then
                        __sedAudioVideoCmd audio "$JOBSLIST"
                        Jobs="${parallel_audio_jobs}"
                    else
                        __sedAudioVideoCmd video "$JOBSLIST"
                        Jobs="${parallel_video_jobs}"
                    fi
                    {
                        parallel \
                        --retry-failed \
                        --joblog "$tmp_dir"/parallel.log \
                        --jobs "${Jobs}" < "$JOBSLIST"
                        __waitForPidToFinish "$@"
                        __cleanListsAndTitles
                    } &
                ;;
                --get-audio|--get-video|--direct-video)
                    if [[ $2 == '--get-audio' ]]; then
                        [[ $M3UFILE != "$AUDIO_URLS" ]] && sed -i '1d' "$M3UFILE"
                        __sedAudioVideoCmd audio "$M3UFILE"
                        Jobs="${parallel_audio_jobs}"
                    else
                        [[ $M3UFILE != "$VIDEO_URLS" ]] && sed -i '1d' "$M3UFILE"
                        __sedAudioVideoCmd video "$M3UFILE"
                        Jobs="${parallel_video_jobs}"
                    fi
                    {
                        parallel \
                        --retry-failed \
                        --joblog "$tmp_dir"/parallel.log \
                        --jobs "${Jobs}" < "$M3UFILE"
                        __waitForPidToFinish "$@"
                        __cleanListsAndTitles
                    } &
                ;;
            esac
        ;;
        xargs)

            while read -r line; do
                [[ $line =~ ^https ]] && https+=("${line}")
            done < "${M3UFILE}"

            __getVideoResolution() {
                local res
                # Extract just the height number from ytdlPreset_MR
                res=$(echo "${ytdlPreset_MR[*]}" | grep -o '<=?[0-9]*')
                if [[ -z $res ]]; then
                    echo "<=?1080"  # Default to 1080p if not found
                else
                    echo "$res"
                fi
            }

            case $2 in
                --choose-audio|--get-audio)
                    printf '%s\n' "${https[@]}" \
                    | xargs -I '{}' -P "${parallel_audio_jobs}" \
                    yt-dlp --format "${ytfmt[1]}" "${ytdlPreset_NC[@]}" {}
                    __waitForPidToFinish "$@"
                    __cleanListsAndTitles
                ;;
                --choose-video|--direct-video|--get-video)
                    local maxHeight
                    maxHeight=$(__getVideoResolution)
                    printf '%s\n' "${https[@]}" \
                    | xargs -I '{}' -P "${parallel_video_jobs}" \
                    yt-dlp --format "bestvideo[height${maxHeight}][vcodec!=vp9]+bestaudio/best" \
                    "${ytdlPreset_X[@]}" {}
                    __waitForPidToFinish "$@"
                    __cleanListsAndTitles
                ;;
            esac

        ;;
    esac

} >/dev/null 2>&1
