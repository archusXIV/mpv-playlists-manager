#!/usr/bin/env bash
## This is a part of main script: mpm.

# shellcheck disable=SC2154
_ParallelDownloadCmd() {

    : "${parallel_audio_jobs:=6}"
    : "${parallel_video_jobs:=3}"
    
    # local parallel_audio_jobs parallel_video_jobs
    # parallel_audio_jobs=6 parallel_video_jobs=3

    __sedCleanListsAndTitles() {
        if [[ $M3UFILE == "$DEFAULT_LIST" ]]; then
            sed -i '1,$d' {"$M3UFILE","$TITLES"}
            echo "#EXTM3U" > "$DEFAULT_LIST"
        elif [[ $M3UFILE == "$SELECTED_URLS1" ]]; then
            sed -i '1,$d' "$SELECTED_TITLES"
        else
            sed -i '1,$d' {"$M3UFILE","$TITLES"}
        fi
        clear
    }

    declare -a ytfmt=(
        "yt-dlp --format"
        "bestaudio"
        "bestvideo+bestaudio/best"
        "${ytdlPreset_MR[@]}"
    )

    # using commas instead of slashes as separators,
    # because we need ${ytfmt[@]:1:2} outside of sed too but later in option xargs.
    __sedAudioCmd() (
        sed -i "s,^,${ytfmt[0]} ${ytfmt[1]} ${ytdlPreset_NC[*]} ," "$1"
    )

    __sedVideoCmd() (
        if [[ ${ytdlPreset_MR[*]} ]]; then
            sed -i "s,^,${ytfmt[0]} ${ytfmt[3]} ${ytdlPreset_X[*]} ," "$1"
        else
            sed -i "s,^,${ytfmt[0]} ${ytfmt[2]} ${ytdlPreset_X[*]} ," "$1"
        fi
    )

    case "$1" in
        parallel)
            case "$2" in
                --choose-audio|--choose-video)
                    cp "$M3UFILE" "$JOBSLIST"
                    if [[ $2 == "--choose-audio" ]]; then
                        __sedAudioCmd "$JOBSLIST"
                        Jobs="${parallel_audio_jobs}"
                    else
                        __sedVideoCmd "$JOBSLIST"
                        Jobs="${parallel_video_jobs}"
                    fi
                    {
                        parallel --jobs "${Jobs}" < "$JOBSLIST"
                        __sedCleanListsAndTitles
                        clear
                    } &
                ;;
                --get-audio|--get-video|--direct-video)
                    if [[ $2 == '--get-audio' ]]; then
                        [[ $M3UFILE != "$AUDIO_URLS" ]] && sed -i '1d' "$M3UFILE"
                        __sedAudioCmd "$M3UFILE"
                        Jobs="${parallel_audio_jobs}"
                    else
                        [[ $M3UFILE != "$VIDEO_URLS" ]] && sed -i '1d' "$M3UFILE"
                        __sedVideoCmd "$M3UFILE"
                        Jobs="${parallel_video_jobs}"
                    fi
                    {
                        parallel --jobs "${Jobs}" < "$M3UFILE"
                        __sedCleanListsAndTitles
                    } &
                ;;
            esac
            rm -f "$JOBSLIST"
        ;;
        xargs)

            while read -r line; do
                [[ $line =~ ^https ]] && https+=("${line}")
            done < "${M3UFILE}"

            __getVideoResolution() {
                local res
                # Extract just the height number from ytdlPreset_MR
                res=$(echo "${ytdlPreset_MR[*]}" | grep -o '<=?[0-9]*')
                if [[ -z $res ]]; then
                    echo "<=?1080"  # Default to 1080p if not found
                else
                    echo "$res"
                fi
            }

            case "$2" in
                --choose-audio|--get-audio)
                    printf '%s\n' "${https[@]}" | xargs -I '{}' -P "${parallel_audio_jobs}" \
                    yt-dlp --format "${ytfmt[1]}" "${ytdlPreset_NC[@]}" {}
                    __sedCleanListsAndTitles
                ;;
                --choose-video|--direct-video|--get-video)
                    local maxHeight
                    maxHeight=$(__getVideoResolution)
                    printf '%s\n' "${https[@]}" | xargs -I '{}' -P "${parallel_video_jobs}" \
                    yt-dlp --format "bestvideo[height${maxHeight}][vcodec!=vp9]+bestaudio/best" \
                    "${ytdlPreset_X[@]}" {}
                    __sedCleanListsAndTitles
                ;;
            esac

        ;;
    esac

} >/dev/null 2>&1
